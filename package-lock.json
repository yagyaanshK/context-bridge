{
  "name": "context-bridge-workspace",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "context-bridge-workspace",
      "version": "0.1.0",
      "license": "MIT",
      "workspaces": [
        "packages/core",
        "packages/cli"
      ],
      "engines": {
        "node": ">=20"
      }
    },
    "node_modules/@context-bridge/core": {
      "resolved": "packages/core",
      "link": true
    },
    "node_modules/context-bridge": {
      "resolved": "packages/cli",
      "link": true
    },
    "packages/cli": {
      "name": "context-bridge",
      "version": "0.1.0",
      "license": "MIT",
      "dependencies": {
        "@context-bridge/core": "0.1.0"
      },
      "bin": {
        "context-bridge": "bin/context-bridge.js"
      },
      "engines": {
        "node": ">=20"
      }
    },
    "packages/core": {
      "name": "@context-bridge/core",
      "version": "0.1.0",
      "license": "MIT",
      "engines": {
        "node": ">=20"
      }
    }
  }
}
